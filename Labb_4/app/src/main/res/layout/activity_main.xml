<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/aldrich"
        android:text="Store ToGo"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnNext"
        android:layout_width="55dp"
        android:layout_height="46dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#1E94E9"
        android:drawableBottom="@drawable/image_next"
        android:fontFamily="sans-serif-black"
        android:onClick="loadMore"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/productList"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnCategories"
        android:layout_width="128dp"
        android:layout_height="55dp"
        android:layout_marginStart="16dp"
        android:backgroundTint="#1E94E9"
        android:drawableEnd="@drawable/image_categories"
        android:fontFamily="sans-serif-black"
        android:onClick="openCategories"
        android:text="CATEGORIES"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/buttonBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/buttonBackground" />

    <Button
        android:id="@+id/btnCart"
        android:layout_width="128dp"
        android:layout_height="55dp"
        android:layout_marginEnd="16dp"
        android:backgroundTint="#1E94E9"
        android:drawableEnd="@drawable/image_cart"
        android:fontFamily="sans-serif-black"
        android:onClick="openCart"
        android:text="CART"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/buttonBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/buttonBackground" />

    <View
        android:id="@+id/buttonBackground"
        android:layout_width="0dp"
        android:layout_height="66dp"
        android:layout_marginTop="8dp"
        android:background="#1F000000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <ListView
        android:id="@+id/productList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonBackground">

    </ListView>

</androidx.constraintlayout.widget.ConstraintLayout>
